NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project URL and anon key for app auth/client access.
# Find both in Supabase Dashboard -> Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth is configured in the Supabase dashboard, not here.
# Add the app callback URL (`/auth/callback`) and provider credentials in
# Supabase/Auth and the Google Cloud Console. `NEXT_PUBLIC_APP_URL` is used to
# build the redirect URL, so `${NEXT_PUBLIC_APP_URL}/auth/callback` must be
# allowed in both Supabase redirect URLs and the Google OAuth client.

# Postgres connection string for server-side SQL tooling such as Drizzle.
# Get it from Supabase Dashboard -> Connect.
# For most local/dev setups, use a pooler connection string if your network does
# not support IPv6. If your environment supports IPv6, the direct connection
# string also works.
POSTGRES_URL=

# OpenAI credentials for realtime interview and report generation.
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_RESPONSES_MODEL=gpt-5.2

# Upstash Redis REST credentials for rate limiting.
# Use the HTTPS endpoint for UPSTASH_REDIS_REST_URL and the REST Token for
# UPSTASH_REDIS_REST_TOKEN from the Upstash Console.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Observability keys.
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
