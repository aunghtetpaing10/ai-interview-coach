NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database connection for product routes and readiness checks.
# DB_MAX_CONNECTIONS is read by the postgres client wrapper.
POSTGRES_URL=
DB_MAX_CONNECTIONS=10

# Supabase project URL and anon key for app auth/client access.
# Find both in Supabase Dashboard -> Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Inngest background jobs for report generation.
INNGEST_APP_ID=ai-interview-coach
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=

# Google OAuth is configured in the Supabase dashboard, not here.
# Add the app callback URL (`/auth/callback`) and provider credentials in
# Supabase/Auth and the Google Cloud Console. `NEXT_PUBLIC_APP_URL` is used to
# build the redirect URL, so `${NEXT_PUBLIC_APP_URL}/auth/callback` must be
# allowed in both Supabase redirect URLs and the Google OAuth client.

# OpenAI credentials for realtime interview and report generation.
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_RESPONSES_MODEL=gpt-5.2

# Upstash Redis REST credentials for rate limiting.
# Use the HTTPS endpoint for UPSTASH_REDIS_REST_URL and the REST Token for
# UPSTASH_REDIS_REST_TOKEN from the Upstash Console.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_MODE=off
RATE_LIMIT_NAMESPACE=ai-interview-coach

# Observability and analytics keys.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
