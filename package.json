{
  "name": "ai-interview-coach",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ignore-pattern coverage --ignore-pattern playwright-report --ignore-pattern test-results",
    "typecheck": "tsc --noEmit",
    "pretest": "node -e \"require('fs').mkdirSync('coverage/.tmp', { recursive: true })\"",
    "test": "vitest run --coverage --config vitest.config.mjs",
    "test:watch": "vitest --config vitest.config.mjs",
    "test:e2e": "playwright test",
    "inngest:dev": "tsx scripts/inngest-dev.ts",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "db:generate": "dotenv -e .env -- drizzle-kit generate",
    "db:push": "dotenv -e .env -- drizzle-kit push",
    "db:seed": "dotenv -e .env -- tsx db/seed-runner.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@sentry/nextjs": "^10.44.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.2",
    "@tanstack/react-query": "^5.91.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "ai": "^6.0.116",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.38.0",
    "inngest": "^4.0.1",
    "lucide-react": "^0.577.0",
    "next": "16.2.0",
    "openai": "^6.32.0",
    "postgres": "^3.4.8",
    "posthog-js": "^1.362.0",
    "posthog-node": "^5.21.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.8.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
